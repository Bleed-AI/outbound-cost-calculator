#!/usr/bin/env bash
# bin/dev — wrapper that injects Doppler secrets into any command.
#
# Usage:
#   bin/dev node scripts/build-list.js
#   bin/dev npm run X
#   bin/dev sh -c 'echo $OPENAI_API_KEY'
#
# Behavior:
#   - First run: doppler.yaml pins project=bleedai, config=prd_outbound-cost-calculator.
#     If the user hasn't run `doppler login` yet, this prints a friendly
#     instruction and exits non-zero so the failure is loud.
#   - Subsequent runs: `doppler run --` injects secrets, runs the inner command.
#
# Subcommands handled directly (don't pass to doppler run):
#   bin/dev pr-approve N              → wraps gh pr merge
#   bin/dev pr-reject N "<reason>"    → wraps gh pr close
#   bin/dev pr-list                   → wraps gh pr list

set -euo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
cd "$ROOT"

# Resolve doppler binary (winget install on Windows lands here, not always on PATH)
if command -v doppler >/dev/null 2>&1; then
  DOPPLER="doppler"
elif [ -x "$LOCALAPPDATA/Microsoft/WinGet/Packages/Doppler.doppler_Microsoft.Winget.Source_8wekyb3d8bbwe/doppler.exe" ]; then
  DOPPLER="$LOCALAPPDATA/Microsoft/WinGet/Packages/Doppler.doppler_Microsoft.Winget.Source_8wekyb3d8bbwe/doppler.exe"
elif [ -x "$USERPROFILE/AppData/Local/Microsoft/WinGet/Packages/Doppler.doppler_Microsoft.Winget.Source_8wekyb3d8bbwe/doppler.exe" ]; then
  DOPPLER="$USERPROFILE/AppData/Local/Microsoft/WinGet/Packages/Doppler.doppler_Microsoft.Winget.Source_8wekyb3d8bbwe/doppler.exe"
else
  echo "ERROR: doppler CLI not found." >&2
  echo "Install: winget install doppler.doppler" >&2
  echo "Auth:    doppler login" >&2
  exit 1
fi

# Verify auth (fast — uses local config, no network call required)
if ! "$DOPPLER" whoami --silent >/dev/null 2>&1; then
  echo "ERROR: doppler not authenticated. Run: doppler login" >&2
  exit 1
fi

# Built-in subcommands
case "${1:-}" in
  pr-approve)
    PR_NUM="${2:?Usage: bin/dev pr-approve N}"
    exec gh pr merge "$PR_NUM" --squash --delete-branch
    ;;
  pr-reject)
    PR_NUM="${2:?Usage: bin/dev pr-reject N \"reason\"}"
    REASON="${3:?Usage: bin/dev pr-reject N \"reason\"}"
    gh pr close "$PR_NUM" --comment "$REASON"
    exit $?
    ;;
  pr-list)
    exec gh pr list --state open
    ;;
  pr-review)
    exec node scripts/pr-review-hub.cjs
    ;;
  "")
    echo "Usage: bin/dev <command> [args...]" >&2
    echo "       bin/dev pr-approve N | pr-reject N \"reason\" | pr-list | pr-review" >&2
    exit 1
    ;;
esac

# Default: inject secrets and run.
exec "$DOPPLER" run --project bleedai --config prd_outbound-cost-calculator -- "$@"
