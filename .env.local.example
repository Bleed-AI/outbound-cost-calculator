# Copy this file to .env.local and fill in your values
# .env.local is gitignored — never commit real secrets

# Resend API key (get from resend.com/api-keys)
RESEND_API_KEY=re_your_key_here

# Optional: custom "from" address (requires verified domain on Resend)
# Defaults to Resend's test sender if not set
# FROM_EMAIL=BleedAI <noreply@bleedai.com>
